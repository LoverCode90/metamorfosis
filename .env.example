# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Square — production catalog (real inventory lives here)
SQUARE_ENVIRONMENT=production
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
NEXT_PUBLIC_SQUARE_APP_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=

# Payment safety — dev/staging only (no real charges until explicitly enabled)
SQUARE_PAYMENTS_LIVE=false
NEXT_PUBLIC_PAYMENT_MODE=test

# Shippo
SHIPPO_API_KEY=

# DeepL
DEEPL_API_KEY=

# Resend — REPLACE FOR PRODUCTION when domain is verified
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@metamorfosisbeauty.com
RESEND_FROM_NAME=Metamorfosis Beauty

# Gemini
GEMINI_API_KEY=

# Cloudflare Turnstile — REPLACE FOR PRODUCTION when domain is configured
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google (Places + Geocoding)
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# App Config — REPLACE FOR PRODUCTION when domain is purchased
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD_CENTS=7000
NEXT_PUBLIC_LOW_STOCK_THRESHOLD=4
NEXT_PUBLIC_SUPPORTED_LOCALES=en,es
NEXT_PUBLIC_DEFAULT_LOCALE=en

# OAuth → configured in Supabase Dashboard (no .env needed)
# Google Sign-In: Supabase → Auth → Providers → Google
# Apple Sign-In: Supabase → Auth → Providers → Apple
