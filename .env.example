# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Square — production catalog + payments
SQUARE_ENVIRONMENT=production
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Square Web Payments SDK (client-side) — both names used for legacy compat
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_APP_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=

# Payment mode: "test" = Square sandbox SDK (no real charges), "live" = production
NEXT_PUBLIC_PAYMENT_MODE=test

# Shippo — live API key (no sandbox needed; NEXT_PUBLIC_PAYMENT_MODE=test prevents charges)
SHIPPO_API_KEY=
# Webhook secret from Shippo dashboard → Webhooks → your endpoint → Secret
SHIPPO_WEBHOOK_SECRET=
# Origin warehouse address (used as shipment FROM address for all Shippo labels)
SHIPPO_FROM_STREET1=211 W B St
# Required for USPS label purchase — seller phone on ship-from address
SHIPPO_FROM_PHONE=
# Seller email on ship-from (falls back to EMAIL_FROM, then support@metamorfosis.com)
SHIPPO_FROM_EMAIL=

# DeepL
DEEPL_API_KEY=

# Resend — REPLACE FOR PRODUCTION when domain is verified
RESEND_API_KEY=
# Friendly "from" address shown in recipients' inbox
EMAIL_FROM=Metamorfosis Beauty <orders@metamorfosis.beauty>

# Gemini
GEMINI_API_KEY=

# Cloudflare Turnstile — REPLACE FOR PRODUCTION when domain is configured
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google (Places + Geocoding)
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# App Config — REPLACE FOR PRODUCTION when domain is purchased
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD_CENTS=7000
NEXT_PUBLIC_LOW_STOCK_THRESHOLD=4
NEXT_PUBLIC_SUPPORTED_LOCALES=en,es
NEXT_PUBLIC_DEFAULT_LOCALE=en

# OAuth → configured in Supabase Dashboard (no .env needed)
# Google Sign-In: Supabase → Auth → Providers → Google
# Apple Sign-In: Supabase → Auth → Providers → Apple
